@model CarritoDto
@{
    ViewData["Title"] = "Mi Carrito de Compras";
}

<div class="container py-5 animate__animated animate__fadeIn">
    <!-- Header Estilo Tech-Modern -->
    <div class="header-glass p-5 mb-5 rounded-5 d-flex flex-column flex-md-row justify-content-between align-items-center shadow-lg position-relative overflow-hidden">
        <div class="header-decor"></div>
        <div class="ps-md-4 position-relative z-1 text-center text-md-start">
            <h1 class="display-5 fw-800 text-white mb-2">
                <i class="fas fa-shopping-cart text-accent me-3"></i>Tu Carrito
            </h1>
            <p class="mb-0 text-white-50 lead-sm">Revisa tu selección antes de procesar el pago seguro.</p>
        </div>
        <div class="pe-md-4 mt-4 mt-md-0 position-relative z-1">
            <a asp-action="Index" class="btn btn-outline-light rounded-pill fw-bold px-4 py-2">
                <i class="fas fa-arrow-left me-2 small"></i>Seguir Comprando
            </a>
        </div>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="card border-0 shadow-soft rounded-5 py-5 text-center">
            <div class="card-body py-5">
                <div class="empty-cart-icon mb-4">
                    <i class="fas fa-shopping-basket fa-5x opacity-20"></i>
                    <div class="icon-pulse"></div>
                </div>
                <h3 class="fw-bold text-white h2">Tu carrito está vacío</h3>
                <p class="text-muted mb-5 mx-auto" style="max-width: 400px;">Parece que aún no has explorado nuestro catálogo. ¡Tenemos miles de historias esperándote!</p>
                <a asp-action="Index" class="btn btn-primary-gradient rounded-pill px-5 py-3 fw-bold shadow-accent">
                    Explorar Catálogo
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Lista de Productos -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-soft rounded-5 overflow-hidden bg-white">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="bg-light-subtle">
                                <tr class="text-uppercase small fw-bold text-muted letter-spacing-1">
                                    <th class="ps-4 py-4">Producto</th>
                                    <th class="text-center">Precio</th>
                                    <th class="text-center">Cant.</th>
                                    <th class="text-end">Subtotal</th>
                                    <th class="pe-4 text-center"></th>
                                </tr>
                            </thead>
                            <tbody class="border-top-0">
                                @foreach (var item in Model.Items)
                                {
                                    <tr class="item-row">
                                        <td class="ps-4 py-4">
                                            <div class="d-flex align-items-center">
                                                <div class="book-mini-cover me-3">
                                                    <i class="fas fa-book fa-lg text-accent"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-white h6 mb-0">@item.Titulo</div>
                                                    <small class="text-muted">Digital / Físico</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center text-muted fw-500">@item.PrecioUnitario <span class="extra-small">Bs</span></td>
                                        <td class="text-center">
                                            <span class="badge bg-light text-white rounded-pill px-3 py-2 border">@item.Cantidad</span>
                                        </td>
                                        <td class="text-end fw-800 text-white">@item.Subtotal <span class="small fw-normal">Bs</span></td>
                                        <td class="pe-4 text-center">
                                            <form asp-action="Remover" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="detalleId" value="@item.Id" />
                                                <button class="btn-remove-item" title="Eliminar del carrito">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Resumen y Pago -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-lg rounded-5 bg-white sticky-top" style="top: 100px;">
                    <div class="card-body p-4 p-xl-5">
                        <h4 class="fw-800 text-white mb-4">Resumen</h4>

                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Subtotal (@Model.Items.Sum(i => i.Cantidad) unid.)</span>
                            <span class="fw-bold text-white">@Model.Total Bs</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4 pb-4 border-bottom">
                            <span class="text-muted">Gestión de envío</span>
                            <span class="fw-bold text-success small text-uppercase">Gratis</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-5">
                            <span class="h5 fw-bold text-white mb-0">Total</span>
                            <div class="text-end">
                                <h3 class="fw-900 text-accent mb-0">@Model.Total Bs</h3>
                                <small class="text-muted extra-small">Impuestos incluidos</small>
                            </div>
                        </div>

                        <form asp-action="Comprar" method="post" id="checkoutForm">
                            @Html.AntiForgeryToken()
                            <div class="mb-4">
                                <label class="form-label fw-bold text-muted small letter-spacing-1">MÉTODO DE PAGO</label>
                                <div class="payment-selector">
                                    <select name="MetodoPago" class="form-select custom-select-lg mb-3" required>
                                        <option value="" disabled selected>Selecciona una opción...</option>
                                        <option value="QR">QR Simple (Transferencia Express)</option>
                                        <option value="Tarjeta">Tarjeta de Crédito / Débito</option>
                                        <option value="Transferencia">Transferencia Bancaria</option>
                                    </select>
                                    <div class="position-relative">
                                        <i class="fas fa-receipt position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                                        <input type="text" name="ReferenciaPago" class="form-control ps-5" placeholder="Nro de comprobante" />
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary-gradient w-100 py-3 rounded-pill fw-bold shadow-accent mt-3">
                                <i class="fas fa-lock me-2"></i>Finalizar Compra
                            </button>

                            <div class="text-center mt-4">
                                <img src="https://upload.wikimedia.org/wikipedia/commons/b/b5/PayPal.svg" height="15" class="opacity-50 me-2" alt="Paypal">
                                <img src="https://upload.wikimedia.org/wikipedia/commons/5/5e/Visa_Inc._logo.svg" height="10" class="opacity-50 me-2" alt="Visa">
                                <img src="https://upload.wikimedia.org/wikipedia/commons/2/2a/Mastercard-logo.svg" height="15" class="opacity-50" alt="Mastercard">
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    :root {
        --dark-deep: #0a0a0a;
        --accent-teal: #8b5cf6;
        --primary-gradient: linear-gradient(135deg, #171717 0%, #0a0a0a 100%);
    }

    .fw-800 {
        font-weight: 800;
    }

    .fw-900 {
        font-weight: 900;
    }

    .letter-spacing-1 {
        letter-spacing: 1px;
    }

    .text-accent {
        color: var(--accent-teal);
    }

    /* Header Glassmorphism */
    .header-glass {
        background: var(--primary-gradient);
        border: 1px solid rgba(255,255,255,0.1);
    }

    .header-decor {
        position: absolute;
        top: -50%;
        right: -10%;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(0,204,205,0.2) 0%, rgba(0,0,0,0) 70%);
        border-radius: 50%;
    }

    /* Iconos y Decoración */
    .book-mini-cover {
        width: 45px;
        height: 45px;
        background: #f1f5f9;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .empty-cart-icon {
        position: relative;
        display: inline-block;
        color: #cbd5e1;
    }

    .btn-remove-item {
        background: transparent;
        border: none;
        color: #ef4444;
        opacity: 0.5;
        transition: all 0.3s ease;
        padding: 8px;
    }

        .btn-remove-item:hover {
            opacity: 1;
            transform: scale(1.2);
        }

    /* Table Styles */
    .item-row {
        transition: background 0.3s ease;
    }

        .item-row:hover {
            background-color: #f8fafc;
        }

    /* Custom Inputs */
    .custom-select-lg, .form-control {
        border: 2px solid #f1f5f9;
        border-radius: 12px;
        padding: 12px;
        font-weight: 500;
    }

        .custom-select-lg:focus, .form-control:focus {
            border-color: var(--accent-teal);
            box-shadow: 0 0 0 4px rgba(0, 204, 205, 0.1);
        }

    .btn-primary-gradient {
        background: var(--primary-gradient);
        color: white;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-primary-gradient:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(15, 23, 42, 0.3);
            color: var(--accent-teal);
        }

    .shadow-soft {
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#checkoutForm').on('submit', function() {
                const btn = $(this).find('button[type="submit"]');
                btn.prop('disabled', true);
                btn.html('<span class="spinner-border spinner-border-sm me-2"></span>Procesando pago...');
            });
        });
    </script>
}