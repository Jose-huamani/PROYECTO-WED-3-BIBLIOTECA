@model List<AuditoriaDto>
@{
    ViewData["Title"] = "Auditoría";
}

<style>
    /* Contenedor con degradado de fondo para coherencia */
    .audit-page-wrapper {
        background: radial-gradient(circle at top right, #0a0a0a 0%, #171717 100%);
        min-height: 100vh;
        padding-top: 40px;
        padding-bottom: 60px;
    }

    /* Tarjeta principal con bordes suaves */
    .audit-card {
        background: rgba(255, 255, 255, 0.98);
        border-radius: 30px;
        border: none;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    }

    /* Cabecera con Glassmorphism oscuro */
    .audit-header {
        background: rgba(15, 23, 42, 0.9) !important;
        backdrop-filter: blur(10px);
        border-bottom: 2px solid #22d3ee;
        padding: 2rem 3rem !important;
    }

    .text-accent-cyan {
        color: #22d3ee;
        text-shadow: 0 0 10px rgba(34, 211, 238, 0.5);
    }

    /* Estilos de la tabla */
    .custom-table thead th {
        background-color: #f8fafc;
        color: #64748b;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
        padding: 1.2rem 1rem;
        border: none;
    }

    .custom-table tbody tr {
        transition: all 0.2s ease;
        border-bottom: 1px solid #f1f5f9;
    }

        .custom-table tbody tr:hover {
            background-color: #f0f9ff;
            transform: scale(1.002);
        }

    /* Badges de acciones */
    .badge-action {
        background: #e0f2fe;
        color: #0369a1;
        font-weight: 700;
        border-radius: 8px;
        padding: 0.5em 1em;
    }

    /* IP Estilizada */
    .ip-box {
        font-family: 'Fira Code', monospace;
        background: #171717;
        color: #22d3ee !important;
        border-radius: 6px;
        padding: 4px 10px;
        font-size: 0.85rem;
    }

    .btn-return {
        background: rgba(255, 255, 255, 0.1);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(5px);
        transition: all 0.3s ease;
    }

        .btn-return:hover {
            background: #22d3ee;
            color: #0a0a0a;
            border-color: #22d3ee;
        }
</style>

<div class="audit-page-wrapper">
    <section class="container animate__animated animate__fadeIn">
        <div class="card audit-card overflow-hidden">
            <!-- HEADER -->
            <div class="card-header audit-header d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-0 fw-bold text-white">
                        <i class="fas fa-user-shield me-2 text-accent-cyan"></i>Registro de Auditoría
                    </h4>
                    <p class="small text-white-50 mb-0 ls-1">TRAZABILIDAD DE OPERACIONES Y SEGURIDAD DEL SISTEMA</p>
                </div>
                <a asp-action="Dashboard" class="btn btn-return rounded-pill px-4">
                    <i class="fas fa-chevron-left me-2"></i>Volver
                </a>
            </div>

            <!-- TABLA -->
            <div class="table-responsive">
                <table class="table align-middle custom-table mb-0">
                    <thead>
                        <tr>
                            <th class="ps-5">Timestamp</th>
                            <th>Acción / Entidad</th>
                            <th>Responsable</th>
                            <th class="text-center">Origen IP</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model)
                        {
                            <tr>
                                <td class="ps-5">
                                    <div class="fw-bold text-dark">@a.Fecha.ToLocalTime().ToString("dd MMM yyyy")</div>
                                    <div class="small text-muted"><i class="far fa-clock me-1"></i>@a.Fecha.ToLocalTime().ToString("HH:mm:ss")</div>
                                </td>
                                <td>
                                    <span class="badge badge-action mb-1">@a.Accion.ToUpper()</span>
                                    <div class="small text-muted">
                                        <span class="text-primary fw-semibold">@a.TipoEntidad</span>
                                        <span class="badge bg-light text-dark border ms-1">ID: #@a.EntidadId</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light p-2 rounded-circle me-2">
                                            <i class="fas fa-user-tag text-secondary"></i>
                                        </div>
                                        <span class="fw-medium text-dark">@a.UsuarioId</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="ip-box shadow-sm">@a.IpAddress</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- FOOTER DE LA TARJETA -->
            <div class="card-footer bg-light p-3 text-center border-0">
                <small class="text-muted">Mostrando @Model.Count registros de actividad reciente.</small>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
}