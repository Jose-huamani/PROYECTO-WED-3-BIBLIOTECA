@{
    ViewData["Title"] = "Consola Técnica";
}

<style>
    :root {
        --dark-dark: #0a0a0a;
        --accent-cyan: #8b5cf6;
        --glow-cyan: rgba(0, 204, 205, 0.2);
    }

    .bg-gradient-dark {
        background: linear-gradient(145deg, #0a0a0a 0%, #171717 100%);
    }

    /* Estilo para el contenedor de iconos circular */
    .icon-shape {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        background: var(--accent-cyan);
    }

    /* Tarjetas de herramientas técnicas */
    .btn-tech-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
    }

        .btn-tech-card:hover {
            background: rgba(0, 204, 205, 0.1);
            border-color: var(--accent-cyan);
            transform: translateY(-5px);
            box-shadow: 0 10px 20px var(--glow-cyan);
        }

        .btn-tech-card i {
            color: var(--accent-cyan);
            transition: 0.3s;
        }

        .btn-tech-card:hover i {
            transform: scale(1.2);
            text-shadow: 0 0 10px var(--accent-cyan);
        }

    .bg-success-soft {
        background-color: rgba(16, 185, 129, 0.15);
    }

    .ls-1 {
        letter-spacing: 1px;
    }

    .extra-small {
        font-size: 0.65rem;
        text-transform: uppercase;
    }
</style>

<div class="container py-5 animate__animated animate__fadeIn">
    <!-- Panel Principal -->
    <div class="card border-0 shadow-lg rounded-5 overflow-hidden bg-gradient-dark">
        <div class="card-body p-4 p-md-5">
            <div class="d-flex align-items-center mb-4">
                <div class="icon-shape me-3 shadow-sm">
                    <i class="fas fa-server text-dark fa-lg"></i>
                </div>
                <div>
                    <h2 class="h3 fw-800 text-white mb-0 text-uppercase ls-1">Núcleo del Sistema</h2>
                    <div class="d-flex align-items-center mt-1">
                        <span class="badge bg-success-soft text-success px-3 py-1 small rounded-pill">
                            <i class="fas fa-circle me-1 extra-small"></i> Servidores Online
                        </span>
                        <span class="ms-3 text-white-50 small"><i class="fas fa-clock me-1"></i> Uptime: 99.9%</span>
                    </div>
                </div>
            </div>

            <p class="text-white-50 mb-5 w-100 w-lg-75">
                Panel de control de infraestructura: Monitoreo de contenedores <strong>Docker</strong>,
                análisis de tráfico de red y gestión de redundancia para bases de datos críticas.
            </p>

            <!-- Grid de Herramientas -->
            <div class="row g-3">
                @{
                    var herramientas = new[] {
                                (T: "Estado Servidor", I: "fa-heartbeat"),
                                (T: "Métricas API", I: "fa-chart-area"),
                                (T: "Logs en Vivo", I: "fa-file-code"),
                                (T: "Nodos Docker", I: "fa-docker"),
                                (T: "Backups DB", I: "fa-database"),
                                (T: "Tráfico Red", I: "fa-network-wired")
                                };
                }

                @foreach (var f in herramientas)
                {
                    <div class="col-6 col-md-4 col-lg-2">
                        <div class="btn-tech-card p-4 rounded-4 text-center h-100 d-flex flex-column align-items-center justify-content-center">
                            <i class="fas @f.I fa-2x d-block mb-3"></i>
                            <span class="extra-small fw-bold text-white opacity-75">@f.T</span>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Footer de Consola (Barra de estado inferior) -->
        <div class="bg-black bg-opacity-25 p-3 px-5 border-top border-white border-opacity-10 d-none d-md-block">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <span class="text-white-50 extra-small"><i class="fas fa-code-branch me-1 text-accent"></i> Rama actual: <strong>main</strong></span>
                    <span class="text-white-50 extra-small ms-3"><i class="fas fa-microchip me-1 text-accent"></i> CPU: <strong>14%</strong></span>
                </div>
                <div class="col-md-6 text-end">
                    <span class="text-white-50 extra-small">Protocolo: <strong>HTTPS/TLS 1.3</strong></span>
                </div>
            </div>
        </div>
    </div>
</div>