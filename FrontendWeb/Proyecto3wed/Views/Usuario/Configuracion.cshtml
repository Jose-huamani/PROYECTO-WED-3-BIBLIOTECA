@{
    ViewData["Title"] = "Configuración";
}

<style>
    .config-card {
        background: white;
        border-radius: 20px;
        padding: 30px;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        margin-bottom: 25px;
    }

    @@media (prefers-color-scheme: dark) {
        .config-card { background: #1e293b; border-color: rgba(255,255,255,0.05); }
    }

    .form-check-input:checked {
        background-color: var(--accent-teal, #0ea5e9);
        border-color: var(--accent-teal, #0ea5e9);
    }
</style>

<div class="container animate__animated animate__fadeIn py-4">
    
    <div class="d-flex align-items-center mb-4">
        <div class="bg-secondary bg-opacity-10 p-3 rounded-circle me-3">
            <i class="fas fa-cog fa-2x text-secondary"></i>
        </div>
        <div>
            <h2 class="fw-bold mb-0">Configuración de la Cuenta</h2>
            <p class="text-muted mb-0">Administra tus preferencias de visualización y notificaciones.</p>
        </div>
    </div>

    <div class="row">
        <!-- Apariencia -->
        <div class="col-md-6">
            <div class="config-card">
                <h4 class="fw-bold mb-4"><i class="fas fa-paint-brush text-primary me-2"></i> Apariencia</h4>
                
                <div class="mb-4">
                    <label class="form-label fw-bold">Tema del Sistema</label>
                    <div class="d-flex gap-3 mt-2">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="themeMode" id="themeLight" checked>
                            <label class="form-check-label" for="themeLight">
                                <i class="fas fa-sun text-warning"></i> Claro
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="themeMode" id="themeDark">
                            <label class="form-check-label" for="themeDark">
                                <i class="fas fa-moon text-secondary"></i> Oscuro
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="themeMode" id="themeAuto">
                            <label class="form-check-label" for="themeAuto">
                                <i class="fas fa-desktop text-info"></i> Automático (Sistema)
                            </label>
                        </div>
                    </div>
                </div>

                <div>
                    <label class="form-label fw-bold">Idioma de la Plataforma</label>
                    <select class="form-select form-select-lg rounded-pill" aria-label="Idioma">
                        <option value="es" selected>Español (Latinoamérica)</option>
                        <option value="en">English (US)</option>
                        <option value="pt">Português (Brasil)</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Notificaciones -->
        <div class="col-md-6">
            <div class="config-card">
                <h4 class="fw-bold mb-4"><i class="fas fa-bell text-warning me-2"></i> Notificaciones</h4>
                
                <div class="form-check form-switch mb-3 fs-5">
                    <input class="form-check-input" type="checkbox" role="switch" id="notifEmail" checked>
                    <label class="form-check-label" for="notifEmail">
                        Recibir correos de vencimiento de préstamos
                    </label>
                </div>
                
                <div class="form-check form-switch mb-3 fs-5">
                    <input class="form-check-input" type="checkbox" role="switch" id="notifReservas" checked>
                    <label class="form-check-label" for="notifReservas">
                        Alertas cuando mi reserva esté disponible
                    </label>
                </div>
                
                <div class="form-check form-switch mb-3 fs-5">
                    <input class="form-check-input" type="checkbox" role="switch" id="notifPromos">
                    <label class="form-check-label" for="notifPromos">
                        Promociones y nuevos libros en tienda
                    </label>
                </div>
            </div>
            
            <div class="text-end">
                <button class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow">
                    <i class="fas fa-save me-2"></i> Guardar Cambios
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Script básico para simular guardado
        document.querySelector('.btn-primary').addEventListener('click', function() {
            const btn = this;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Guardando...';
            btn.disabled = true;
            
            setTimeout(() => {
                btn.innerHTML = '<i class="fas fa-check me-2"></i> Guardado';
                btn.classList.replace('btn-primary', 'btn-success');
                
                setTimeout(() => {
                    btn.innerHTML = originalText;
                    btn.classList.replace('btn-success', 'btn-primary');
                    btn.disabled = false;
                }, 2000);
            }, 1000);
        });
    </script>
}
