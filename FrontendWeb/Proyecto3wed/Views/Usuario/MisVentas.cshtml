@model List<Proyecto3wed.Models.VentaDto>

@{
    ViewData["Title"] = "Mis Compras";
}

<div class="container mt-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fas fa-shopping-bag brand-accent me-2"></i> Mis Compras</h2>
        <a asp-controller="Tienda" asp-action="Index" class="btn btn-outline-secondary rounded-pill shadow-sm">
            <i class="fas fa-store me-1"></i> Ir a la Tienda
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 text-center p-5">
            <i class="fas fa-box-open fa-4x text-muted mb-3 opacity-50"></i>
            <h4 class="fw-bold text-muted">Aún no has realizado ninguna compra</h4>
            <p class="text-secondary mb-4">Explora nuestra tienda y encuentra los mejores libros.</p>
            <a asp-controller="Tienda" asp-action="Index" class="btn btn-accent-pill">Descubrir Libros</a>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Fecha</th>
                            <th>Nº Comprobante</th>
                            <th>Total Pagado</th>
                            <th>Método</th>
                            <th>Libros Comprados</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var venta in Model)
                        {
                            <tr>
                                <td>@venta.FechaVenta.ToString("dd/MM/yyyy HH:mm")</td>
                                <td><span class="badge bg-secondary">#@venta.Id.ToString("D6")</span></td>
                                <td><strong class="text-success">@venta.Total.ToString("C")</strong></td>
                                <td>@venta.MetodoPago</td>
                                <td>
                                    <span class="small text-muted"><i class="fas fa-box"></i> Productos del Pedido</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
