@{
    ViewData["Title"] = "Consola de Ajustes";
}

<style>
    :root {
        --dark-dark: #0a0a0a;
        --accent-cyan: #8b5cf6;
        --glow-cyan: rgba(0, 204, 205, 0.3);
        --slate-800: #171717;
    }

    /* --- ANIMACIONES --- */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-panel {
        animation: fadeInUp 0.6s ease-out forwards;
    }

    /* --- CONTENEDORES DE ICONOS --- */
    .icon-shape {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 14px;
        font-size: 1.25rem;
        transition: transform 0.3s ease;
    }

    .card:hover .icon-shape {
        transform: scale(1.1) rotate(5deg);
    }

    .bg-accent-cyan {
        background-color: var(--accent-cyan);
    }

    .text-white {
        color: var(--dark-dark);
    }

    .bg-dark {
        background-color: var(--dark-dark);
        color: var(--accent-cyan);
    }

    /* --- BOTONES ESTILO GLASS --- */
    .btn-glass-sm {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: white;
        padding: 10px;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
        text-align: center;
        transition: all 0.3s ease;
        cursor: pointer;
    }

        .btn-glass-sm:hover {
            background: rgba(255, 255, 255, 0.15);
            border-color: var(--accent-cyan);
            color: var(--accent-cyan);
            transform: translateY(-2px);
        }

    /* --- BOTONES DE ACCIÓN --- */
    .btn-dark-accent {
        background: var(--dark-dark);
        color: var(--accent-cyan);
        border: none;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(15, 23, 42, 0.2);
    }

        .btn-dark-accent:hover {
            background: var(--accent-cyan);
            color: var(--dark-dark);
            box-shadow: 0 8px 20px var(--glow-cyan);
            transform: translateY(-2px);
        }

    /* --- CARDS --- */
    .rounded-5 {
        border-radius: 2rem !important;
    }

    .fw-800 {
        font-weight: 800;
    }

    .ls-2 {
        letter-spacing: 2px;
    }
</style>

<div class="container py-5 animate-panel">
    <!-- Encabezado de la Consola -->
    <div class="mb-5">
        <span class="badge bg-dark px-3 py-2 rounded-pill mb-2 fw-bold ls-2">SYSTEM CONFIG</span>
        <h1 class="display-5 fw-800 text-white">Consola de Ajustes</h1>
        <p class="text-muted">Gestione los parámetros globales y motores de comunicación del ecosistema.</p>
    </div>

    <div class="row g-4">
        <!-- Panel de Alertas & Notificaciones -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-5 overflow-hidden h-100"
                 style="background: linear-gradient(135deg, #0a0a0a 0%, #334155 100%);">
                <div class="card-body p-5 position-relative">
                    <!-- Decoración de fondo -->
                    <div style="position: absolute; top: -20px; right: -20px; width: 150px; height: 150px; background: radial-gradient(circle, rgba(0,204,205,0.1) 0%, transparent 70%); pointer-events: none;"></div>

                    <div class="d-flex align-items-center mb-4">
                        <div class="icon-shape bg-accent-cyan me-3 shadow-lg">
                            <i class="fas fa-satellite-dish text-dark"></i>
                        </div>
                        <h2 class="h4 fw-800 text-white mb-0">Alertas & Notificaciones</h2>
                    </div>

                    <p class="text-white-50 small mb-4">Motor de comunicación omnicanal diseñado para gestionar Emails, notificaciones Push y recordatorios automáticos de mora.</p>

                    <form asp-controller="Admin" asp-action="EnviarNotificacion" method="post" class="mt-4">
                        <div class="mb-3">
                            <label class="form-label text-white small fw-bold">Seleccionar Usuario</label>
                            <select name="usuarioId" class="form-select bg-dark text-white border-secondary shadow-sm" required>
                                <option value="">-- Buscar usuario por correo o nombre --</option>
                                @if (ViewBag.Usuarios != null)
                                {
                                    foreach (var u in ViewBag.Usuarios)
                                    {
                                        <option value="@u.Id">@u.Email - @u.NombreCompleto</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-white small fw-bold">Título de Notificación</label>
                            <input type="text" name="titulo" class="form-control bg-dark text-white border-secondary shadow-sm" placeholder="Ej: Aviso de mora, Reserva lista..." required maxlength="100">
                        </div>
                        <div class="mb-4">
                            <label class="form-label text-white small fw-bold">Mensaje</label>
                            <textarea name="mensaje" class="form-control bg-dark text-white border-secondary shadow-sm" rows="3" placeholder="Detalle el mensaje que recibirá el usuario..." required maxlength="500"></textarea>
                        </div>
                        
                        <div class="d-grid">
                            <button type="submit" class="btn btn-dark-accent rounded-pill fw-bold py-2 shadow-sm d-flex align-items-center justify-content-center gap-2">
                                <i class="fas fa-paper-plane"></i> Enviar Notificación al Usuario
                            </button>
                        </div>
                    </form>

                    <div class="mt-5 p-3 rounded-4" style="background: rgba(255,255,255,0.03); border: 1px dashed rgba(255,255,255,0.1);">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-white-50 small">Estado del Servidor SMTP</span>
                            <span class="badge bg-success rounded-pill" style="font-size: 0.6rem;">ACTIVO</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel de Parámetros Maestros -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-5 bg-white border-top border-4 border-accent-cyan h-100">
                <div class="card-body p-5">
                    <div class="d-flex align-items-center mb-4">
                        <div class="icon-shape bg-light me-3 shadow-sm border">
                            <i class="fas fa-cogs text-white"></i>
                        </div>
                        <h2 class="h4 fw-800 text-white mb-0">Parámetros Maestros</h2>
                    </div>

                    <p class="text-muted small mb-4">Defina las reglas de negocio críticas: límites de préstamos por usuario, costos de multas diarias y políticas operativas.</p>

                    <div class="d-flex flex-wrap gap-2 mb-4">
                        <div class="p-2 px-3 bg-dark rounded-pill d-flex align-items-center">
                            <i class="fas fa-money-bill-wave me-2" style="font-size: 0.8rem;"></i>
                            <span class="small fw-bold">Multas: Bs 5.00/día</span>
                        </div>
                        <div class="p-2 px-3 bg-light text-white border rounded-pill d-flex align-items-center">
                            <i class="fas fa-book me-2" style="font-size: 0.8rem;"></i>
                            <span class="small fw-bold">Máx: 5 libros</span>
                        </div>
                        <div class="p-2 px-3 bg-light text-white border rounded-pill d-flex align-items-center">
                            <i class="fas fa-clock me-2" style="font-size: 0.8rem;"></i>
                            <span class="small fw-bold">Plazo: 7 días</span>
                        </div>
                    </div>

                    <div class="list-group list-group-flush mb-4">
                        <div class="list-group-item px-0 bg-transparent border-light d-flex justify-content-between align-items-center">
                            <span class="small text-muted">Renovación automática</span>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" checked>
                            </div>
                        </div>
                        <div class="list-group-item px-0 bg-transparent border-light d-flex justify-content-between align-items-center">
                            <span class="small text-muted">Registro público de usuarios</span>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox">
                            </div>
                        </div>
                    </div>

                    <button class="btn btn-dark-accent w-100 rounded-pill mt-2 fw-bold py-3 shadow">
                        <i class="fas fa-save me-2"></i>Editar Reglas de Acceso
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>