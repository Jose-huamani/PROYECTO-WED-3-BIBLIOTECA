@model List<ReservaAdminDto>
@{
    ViewData["Title"] = "Gestión de Reservas";

    // Función local para determinar el color según el estado
    string EstadoCss(string e) => e.ToLower().Contains("pendiente")
        ? "bg-warning-soft text-warning"
        : (e.ToLower().Contains("confirmada") ? "bg-success-soft text-success" : "bg-primary-soft text-primary");
}

<style>
    /* Estilos para badges "Soft" */
    .bg-warning-soft {
        background-color: rgba(255, 193, 7, 0.15);
    }

    .bg-primary-soft {
        background-color: rgba(13, 110, 253, 0.15);
    }

    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.15);
    }

    .text-white {
        color: #0a0a0a;
    }

    .ls-2 {
        letter-spacing: 2px;
    }

    .fw-800 {
        font-weight: 800;
    }

    .extra-small {
        font-size: 0.75rem;
    }

    /* Hover en filas de tabla */
    .custom-table tbody tr {
        transition: background-color 0.2s;
    }

        .custom-table tbody tr:hover {
            background-color: #f8fafc;
        }

    .btn-dark-accent {
        background: #0a0a0a;
        color: #8b5cf6;
        border: none;
        transition: 0.3s;
    }

        .btn-dark-accent:hover {
            background: #8b5cf6;
            color: #0a0a0a;
        }
</style>

<div class="container py-5 animate__animated animate__fadeIn">
    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-end mb-4 px-2">
        <div>
            <span class="text-primary fw-bold text-uppercase small ls-2">Solicitudes</span>
            <h1 class="display-6 fw-800 text-white mb-0">Gestión de Reservas</h1>
        </div>
        <a asp-action="Dashboard" class="btn btn-dark-accent rounded-pill px-4 shadow-sm">
            <i class="fas fa-arrow-left me-2"></i>Panel
        </a>
    </div>

    <!-- Contenedor de Tabla -->
    <div class="card border-0 shadow-lg rounded-5 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table align-middle mb-0 custom-table">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0 text-muted small text-uppercase fw-bold">Reserva / Fecha</th>
                        <th class="border-0 text-muted small text-uppercase fw-bold">Usuario</th>
                        <th class="border-0 text-muted small text-uppercase fw-bold">Libro Solicitado</th>
                        <th class="border-0 text-center text-muted small text-uppercase fw-bold">Estado</th>
                        <th class="pe-4 text-end border-0 text-muted small text-uppercase fw-bold">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="ps-4 py-4">
                                <div class="fw-bold text-white">#@r.Id</div>
                                <div class="extra-small text-muted">
                                    <i class="far fa-calendar-alt me-1"></i>@r.FechaReserva.ToString("dd MMM, hh:mm tt")
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-light rounded-circle p-2 me-2 text-center" style="width:35px">
                                        <i class="fas fa-user-circle text-secondary"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark mb-0" style="font-size: 0.9rem;">@r.Usuario?.NombreCompleto</div>
                                        <div class="extra-small text-primary">@r.Usuario?.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="d-inline-block text-truncate fw-medium text-white" style="max-width: 220px;" title="@r.Libro?.Titulo">
                                    <i class="fas fa-book-bookmark me-2 opacity-50 text-primary"></i>@r.Libro?.Titulo
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="badge rounded-pill px-3 py-2 fw-bold @EstadoCss(r.EstadoNombre ?? "Pendiente")">
                                    <i class="fas fa-circle me-1" style="font-size: 0.5rem;"></i>
                                    @(r.EstadoNombre ?? "Pendiente")
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <div class="dropdown">
                                    <button class="btn btn-light btn-sm rounded-circle shadow-sm" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="fas fa-ellipsis-v p-1 text-muted"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg rounded-4 p-2">
                                        <li>
                                            <a class="dropdown-item rounded-3 py-2" href="#">
                                                <i class="fas fa-check-circle text-success me-2"></i>Confirmar Reserva
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item rounded-3 py-2 text-danger" href="#">
                                                <i class="fas fa-times-circle me-2"></i>Cancelar
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item rounded-3 py-2" href="#">
                                                <i class="fas fa-eye me-2 text-primary"></i>Ver Perfil Usuario
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>