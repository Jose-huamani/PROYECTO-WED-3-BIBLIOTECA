@model List<LibroDto>
@{
    ViewData["Title"] = "Gestión de Inventario de Libros";
}

<!-- Estilos Ultra-Modernos Integrados -->
<style>
    :root {
        --dark: #0a0a0a;
        --accent-cyan: #8b5cf6;
        --glow-cyan: rgba(0, 204, 205, 0.4);
        --slate-500: #64748b;
        --slate-100: #f1f5f9;
        --danger: #ef4444;
        --glass-white: rgba(255, 255, 255, 0.85);
    }

    /* --- ANIMACIONES --- */
    @@keyframes slideUp {
        from {
            transform: translateY(15px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    /* --- ESTRUCTURA BASE --- */
    .admin-shell {
        background: #f8fafc;
        min-height: 100vh;
        padding-bottom: 3rem;
        font-family: 'Inter', sans-serif;
    }

    /* --- HEADER PREMIUM --- */
    .admin-header-card {
        background: linear-gradient(135deg, var(--dark) 0%, #171717 100%);
        border-radius: 1.5rem;
        position: relative;
        overflow: hidden;
        color: white;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .bg-decoration {
        position: absolute;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(0,204,205,0.15) 0%, transparent 70%);
        top: -150px;
        right: -50px;
        pointer-events: none;
    }

    /* --- BOTONES CON EFECTO GLOW --- */
    .btn-accent-cyan {
        background: var(--accent-cyan);
        color: var(--dark);
        box-shadow: 0 4px 15px var(--glow-cyan);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

        .btn-accent-cyan:hover {
            transform: scale(1.05) translateY(-3px);
            box-shadow: 0 8px 25px var(--glow-cyan);
            background: #00e5e6;
        }

    /* --- TABLA & TARJETA --- */
    .admin-table-card {
        background: var(--glass-white);
        backdrop-filter: blur(12px);
        border-radius: 1.5rem;
        border: 1px solid rgba(255, 255, 255, 0.5);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }

    .custom-table thead th {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--slate-500);
        background: rgba(241, 245, 249, 0.6);
        padding: 1.25rem 1rem;
        border: none;
    }

    .custom-table tbody tr {
        transition: all 0.25s ease;
        animation: slideUp 0.4s ease forwards;
    }

        .custom-table tbody tr:hover {
            background: white !important;
            box-shadow: inset 4px 0 0 var(--accent-cyan), 0 5px 15px rgba(0,0,0,0.05);
            transform: scale(1.002);
        }

    /* --- PORTADAS 3D --- */
    .book-frame {
        width: 45px;
        height: 60px;
        border-radius: 8px;
        overflow: hidden;
        background: #e2e8f0;
        box-shadow: 3px 3px 10px rgba(0,0,0,0.1);
        transition: transform 0.3s ease;
        perspective: 1000px;
    }

    tr:hover .book-frame {
        transform: rotateY(-15deg) scale(1.1);
    }

    .book-img-thumb {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* --- CONTROLES Y CRUD --- */
    .btn-edit-main {
        background: white;
        color: var(--dark);
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        padding: 6px 16px;
        font-weight: 700;
        transition: all 0.3s ease;
    }

        .btn-edit-main:hover {
            background: var(--dark);
            color: var(--accent-cyan);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.15);
        }

    .btn-tool {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        border: none;
        background: white;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        transition: 0.3s;
    }

        .btn-tool:hover {
            background: var(--dark);
            color: var(--accent-cyan) !important;
            transform: translateY(-3px);
        }

    .status-pill {
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        border: 1px solid transparent;
    }

        .status-pill.ok {
            background: #ecfdf5;
            color: #059669;
            border-color: #10b98133;
        }

        .status-pill.danger {
            background: #fee2e2;
            color: #991b1b;
            border-color: #ef444433;
        }

    /* --- MODALES --- */
    .modal-edit-custom {
        backdrop-filter: blur(8px);
    }

        .modal-edit-custom .modal-content {
            border-radius: 2rem;
            border: none;
        }

        .modal-edit-custom .modal-header {
            background: var(--dark);
            color: white;
            padding: 1.5rem 2rem;
        }

    .form-input-edit {
        border-radius: 1rem;
        border: 1.5px solid #f1f5f9;
        padding: 0.75rem 1.25rem;
        transition: 0.2s;
    }

        .form-input-edit:focus {
            border-color: var(--accent-cyan);
            box-shadow: 0 0 0 4px rgba(0, 204, 205, 0.1);
            outline: none;
        }
</style>

<div class="admin-shell">
    <div class="container py-4">
        <!-- Header -->
        <div class="admin-header-card p-4 p-md-5 mb-4">
            <div class="row align-items-center position-relative z-index-10">
                <div class="col-md-7">
                    <span class="badge bg-accent-cyan text-white fw-bold mb-2 px-3 shadow-sm">SISTEMA DE GESTIÓN</span>
                    <h1 class="fw-800 display-6 mb-1">Catálogo de Libros</h1>
                    <p class="text-white-50 mb-0">Control total de inventario, códigos QR y reportes en tiempo real.</p>
                </div>
                <div class="col-md-5 text-md-end mt-3 mt-md-0">
                    <a asp-action="NuevoLibro" class="btn btn-accent-cyan rounded-pill px-4 fw-bold me-2 shadow">
                        <i class="fas fa-plus me-2"></i>Nuevo Libro
                    </a>
                    <a asp-action="Dashboard" class="btn btn-outline-light rounded-pill px-4 fw-bold opacity-75">Panel</a>
                </div>
            </div>
            <div class="bg-decoration"></div>
        </div>

        <!-- Barra de Búsqueda -->
        <div class="row mb-4 g-3">
            <div class="col-md-9">
                <div class="position-relative shadow-sm rounded-4 overflow-hidden">
                    <i class="fas fa-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input class="form-control border-0 py-3 ps-5 bg-white" id="bookFilter" placeholder="Filtrar por título, autor, ISBN..." />
                </div>
            </div>
            <div class="col-md-3">
                <div class="dropdown h-100">
                    <button class="btn btn-white border-0 shadow-sm w-100 h-100 rounded-4 fw-bold text-muted dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="fas fa-file-export me-2"></i>Herramientas
                    </button>
                    <ul class="dropdown-menu w-100 shadow-lg border-0 rounded-3">
                        <li><a class="dropdown-item fw-bold text-success" asp-action="ExportarLibrosExcel"><i class="fas fa-file-excel me-2"></i>Exportar Excel</a></li>
                        <li><a class="dropdown-item fw-bold text-danger" asp-action="ExportarLibrosPdf"><i class="fas fa-file-pdf me-2"></i>Exportar PDF</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item fw-bold text-primary" href="#" data-bs-toggle="modal" data-bs-target="#importExcelModal"><i class="fas fa-upload me-2"></i>Importar Excel</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Tabla -->
        <div class="card admin-table-card overflow-hidden">
            <div class="table-responsive">
                <table class="table align-middle custom-table mb-0" id="booksTable">
                    <thead>
                        <tr>
                            <th class="ps-4">Ejemplar</th>
                            <th>Autor / Categoría</th>
                            <th>Stock</th>
                            <th>Estado</th>
                            <th class="text-center">Codificación</th>
                            <th class="text-end pe-4">Gestión</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var l in Model)
                        {
                            var pct = (l.CantidadTotal > 0) ? (l.CantidadDisponible * 100 / l.CantidadTotal) : 0;
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="book-frame me-3">
                                            @if (!string.IsNullOrWhiteSpace(l.ImagenUrl))
                                            {
                                                <img src="@l.ImagenUrl" class="book-img-thumb" />
                                            }
                                            else
                                            {
                                                <div class="book-img-thumb d-flex align-items-center justify-content-center bg-light text-muted small fw-bold">LIBRO</div>
                                            }
                                        </div>
                                        <div>
                                            <div class="fw-bold text-white mb-0">@l.Titulo</div>
                                            <small class="text-muted">ISBN @l.Isbn</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="small fw-bold">@l.Autor?.Nombre</div>
                                    <div class="extra-small text-muted text-uppercase">@l.Categoria?.Nombre</div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="fw-800 text-white" style="font-size: 0.85rem;">@l.CantidadDisponible / @l.CantidadTotal</span>
                                        <div class="progress rounded-pill mt-2" style="height: 6px; width: 80px; background: #e2e8f0;">
                                            <div class="progress-bar rounded-pill @(pct < 30 ? "bg-danger" : "bg-info")"
                                                 style="width: @pct%; box-shadow: 0 0 8px @(pct < 30 ? "rgba(239,68,68,0.3)" : "rgba(0,204,205,0.3)");">
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="status-pill @(l.EstaDisponible ? "ok" : "danger")">@(l.EstaDisponible ? "Disponible" : "Sin stock")</span></td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <button class="btn btn-tool" data-bs-toggle="modal" data-bs-target="#qr-@l.Id"><i class="fas fa-qrcode text-info"></i></button>
                                        <button class="btn btn-tool" data-bs-toggle="modal" data-bs-target="#bar-@l.Id"><i class="fas fa-barcode text-white"></i></button>
                                    </div>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end align-items-center">
                                        <button class="btn btn-edit-main me-2 shadow-sm" data-bs-toggle="modal" data-bs-target="#edit-@l.Id">
                                            <i class="fas fa-edit me-2"></i>Editar
                                        </button>
                                        <div class="btn-group rounded-pill overflow-hidden border shadow-sm">
                                            <button class="btn btn-white btn-sm px-3 fw-bold border-0" data-bs-toggle="modal" data-bs-target="#details-@l.Id">Detalles</button>
                                            <button class="btn btn-white btn-sm px-3 text-danger border-0 border-start" data-bs-toggle="modal" data-bs-target="#delete-@l.Id"><i class="fas fa-trash-alt"></i></button>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modales -->
@foreach (var l in Model)
{
    <!-- MODAL EDITAR -->
    <div class="modal fade modal-edit-custom" id="edit-@l.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content shadow-2xl">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold"><i class="fas fa-pen-nib me-2"></i>Editar Libro</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="EditarLibro" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@l.Id" />
                    <input type="hidden" name="CodigoQR" value="@l.CodigoQR" />
                    <input type="hidden" name="CodigoBarras" value="@l.CodigoBarras" />
                    <input type="hidden" name="FechaIngreso" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    <div class="modal-body p-4 p-md-5">
                        <div class="row g-4">
                            <div class="col-12">
                                <label class="text-muted small fw-bold text-uppercase mb-2 d-block">Título</label>
                                <input type="text" name="Titulo" class="form-control form-input-edit w-100" value="@l.Titulo" required />
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted small fw-bold text-uppercase mb-2 d-block">ISBN</label>
                                <input type="text" name="Isbn" class="form-control form-input-edit" value="@l.Isbn" required />
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted small fw-bold text-uppercase mb-2 d-block">Precio Venta (Bs)</label>
                                <input type="number" step="0.01" name="Precio" class="form-control form-input-edit" value="@l.Precio.ToString(System.Globalization.CultureInfo.InvariantCulture)" required />
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted small fw-bold text-uppercase mb-2 d-block">Stock Total</label>
                                <input type="number" name="CantidadTotal" class="form-control form-input-edit" value="@l.CantidadTotal" required />
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted small fw-bold text-uppercase mb-2 d-block">Stock Disponible</label>
                                <input type="number" name="CantidadDisponible" class="form-control form-input-edit" value="@l.CantidadDisponible" required />
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted small fw-bold text-uppercase mb-2 d-block">Autor (Nombre)</label>
                                <input type="text" name="AutorNombre" class="form-control form-input-edit" value="@l.Autor?.Nombre" required />
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted small fw-bold text-uppercase mb-2 d-block">Categoría (Nombre)</label>
                                <input type="text" name="CategoriaNombre" class="form-control form-input-edit" value="@l.Categoria?.Nombre" required />
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted small fw-bold text-uppercase mb-2 d-block">Editorial</label>
                                <input type="text" name="Editorial" class="form-control form-input-edit" value="@l.Editorial" />
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted small fw-bold text-uppercase mb-2 d-block">URL Portada</label>
                                <input type="url" name="ImagenUrl" class="form-control form-input-edit" value="@l.ImagenUrl" />
                            </div>
                            <div class="col-12">
                                <label class="text-muted small fw-bold text-uppercase mb-2 d-block">Descripción</label>
                                <textarea name="Descripcion" class="form-control form-input-edit" rows="3">@l.Descripcion</textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4">
                        <button type="button" class="btn btn-link text-muted fw-bold text-decoration-none me-3" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-accent-cyan px-5 rounded-pill fw-bold">Guardar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- MODAL ELIMINAR -->
    <div class="modal fade" id="delete-@l.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0 rounded-4">
                <div class="modal-body text-center p-5">
                    <div class="text-danger mb-4">
                        <i class="fas fa-exclamation-triangle fa-4x"></i>
                    </div>
                    <h4 class="fw-bold mb-3">¿Eliminar "@l.Titulo"?</h4>
                    <p class="text-muted mb-4">Esta acción no se puede deshacer y borrará todo el historial del ejemplar.</p>
                    <form asp-action="EliminarLibro" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@l.Id" />
                        <button type="button" class="btn btn-light rounded-pill px-4 me-2 fw-bold" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">Sí, eliminar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL DETALLES -->
    <div class="modal fade" id="details-@l.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0 rounded-4">
                <div class="modal-header border-0 pb-0">
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 pt-0">
                    <div class="text-center mb-4">
                        @if (!string.IsNullOrEmpty(l.ImagenUrl))
                        {
                            <img src="@l.ImagenUrl" class="rounded-3 shadow-sm mb-3" style="max-width: 150px; aspect-ratio: 2/3; object-fit: cover;" />
                        }
                        <h4 class="fw-bold text-dark mb-1">@l.Titulo</h4>
                        <p class="text-muted small">@l.Autor?.Nombre • @l.Categoria?.Nombre</p>
                    </div>
                    <div class="bg-light p-3 rounded-3 small">
                        <p class="mb-1"><strong>Editorial:</strong> @(l.Editorial ?? "N/A")</p>
                        <p class="mb-1"><strong>Precio:</strong> @l.Precio.ToString("C")</p>
                        <p class="mb-1"><strong>Descripción:</strong> @(l.Descripcion ?? "Sin descripción.")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL QR -->
    <div class="modal fade" id="qr-@l.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content shadow-lg border-0 rounded-4 text-center p-4">
                <h6 class="fw-bold text-muted mb-3">Código QR de Escaneo</h6>
                <img src="@Url.Action("QrLibroPng", "Catalogo", new { id = l.Id })" class="img-fluid border p-2 rounded-3 mb-3" />
                <code class="d-block text-dark fw-bold bg-light py-2 rounded-3">@l.CodigoQR</code>
            </div>
        </div>
    </div>

    <!-- MODAL BARCODE -->
    <div class="modal fade" id="bar-@l.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content shadow-lg border-0 rounded-4 text-center p-4">
                <h6 class="fw-bold text-muted mb-3">Código de Barras</h6>
                <div class="bg-light p-4 rounded-3 mb-3 d-flex justify-content-center align-items-center" style="height: 100px;">
                    <i class="fas fa-barcode fa-4x text-dark"></i>
                </div>
                <code class="d-block text-dark fw-bold bg-light py-2 rounded-3">@l.CodigoBarras</code>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Filtrado Fluido con Animación
        const filter = document.getElementById('bookFilter');
        const rows = document.querySelectorAll('#booksTable tbody tr');

        filter?.addEventListener('input', (e) => {
            const value = e.target.value.toLowerCase();
            rows.forEach((row, index) => {
                const text = row.innerText.toLowerCase();
                const isMatch = text.includes(value);

                if(isMatch) {
                    row.style.display = '';
                    row.style.animation = `slideUp 0.3s ease forwards ${index * 0.02}s`;
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
}