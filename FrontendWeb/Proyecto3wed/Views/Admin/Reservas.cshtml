@model List<ReservaAdminDto>
@{
    ViewData["Title"] = "Reservas";
    string EstadoCss(string e) => e.ToLower().Contains("pendiente") ? "bg-warning-soft text-warning" : "bg-primary-soft text-primary";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <span class="text-primary fw-bold text-uppercase small ls-2">Solicitudes</span>
            <h1 class="display-6 fw-800 text-white mb-0">Gestión de Reservas</h1>
        </div>
        <a asp-action="Dashboard" class="btn btn-dark-accent rounded-pill px-4 shadow-sm">
            <i class="fas fa-arrow-left me-2"></i>Panel
        </a>
    </div>

    <div class="card border-0 shadow-lg rounded-5 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table align-middle mb-0 custom-table">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Reserva / Fecha</th>
                        <th>Usuario</th>
                        <th>Libro Solicitado</th>
                        <th class="text-center">Estado</th>
                        <th class="pe-4 text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="ps-4 py-4">
                                <div class="fw-bold text-white">#@r.Id</div>
                                <div class="extra-small text-muted">@r.FechaReserva.ToString("dd MMM, hh:mm tt")</div>
                            </td>
                            <td>
                                <div class="fw-bold">@r.Usuario?.NombreCompleto</div>
                                <div class="extra-small text-primary">@r.Usuario?.Email</div>
                            </td>
                            <td>
                                <span class="d-inline-block text-truncate fw-medium" style="max-width: 200px;">
                                    <i class="fas fa-book me-2 opacity-50"></i>@r.Libro?.Titulo
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="badge rounded-pill px-3 py-2 @EstadoCss(r.EstadoNombre ?? "Pendiente")">
                                    @(r.EstadoNombre ?? "Pendiente")
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <button class="btn btn-light btn-sm rounded-circle shadow-sm" title="Ver Detalles">
                                    <i class="fas fa-ellipsis-v p-1"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>