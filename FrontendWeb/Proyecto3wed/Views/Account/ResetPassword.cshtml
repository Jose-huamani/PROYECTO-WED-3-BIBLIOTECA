@model ResetPasswordFormModel
@{
    ViewData["Title"] = "Nueva contraseña";
}

<style>
    /* Contenedor principal con el mismo degradado que el Registro */
    .auth-wrapper {
        background: radial-gradient(circle at top left, #6a11cb 0%, #2575fc 50%, #00d2ff 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', Roboto, sans-serif;
        padding: 20px;
    }

    /* Tarjeta estilo Cristal */
    .glass-card {
        background: rgba(255, 255, 255, 0.12);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 24px;
        padding: 40px;
        width: 100%;
        max-width: 500px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
    }

    .glass-header h1 {
        color: #ffffff;
        font-weight: 700;
        text-shadow: 0 0 10px rgba(0, 210, 255, 0.5);
    }

    /* Inputs Modernos */
    .glass-card .form-control {
        background: rgba(255, 255, 255, 0.08) !important;
        border: 1px solid rgba(255, 255, 255, 0.3) !important;
        color: white !important;
        border-radius: 12px;
        padding: 12px 15px;
    }

        .glass-card .form-control:focus {
            background: rgba(255, 255, 255, 0.15) !important;
            border-color: #00d2ff !important;
            box-shadow: 0 0 12px rgba(0, 210, 255, 0.3) !important;
        }

    /* Estilo para el código de recuperación (Monospace) */
    .token-input {
        letter-spacing: 2px;
        font-family: 'Courier New', Courier, monospace;
        text-transform: uppercase;
    }

    .glass-card .form-label {
        color: rgba(255, 255, 255, 0.9);
        font-size: 0.9rem;
        margin-left: 5px;
    }

    /* Botón de acción principal */
    .btn-update {
        background: linear-gradient(90deg, #007bff, #00d2ff);
        border: none;
        border-radius: 12px;
        color: white;
        font-weight: 600;
        padding: 12px;
        transition: all 0.3s ease;
        margin-top: 20px;
    }

        .btn-update:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 210, 255, 0.4);
            filter: brightness(1.1);
        }

    .link-back {
        color: #00d2ff;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
    }

        .link-back:hover {
            text-decoration: underline;
        }
</style>

<div class="auth-wrapper">
    <div class="glass-card">
        <div class="glass-header text-center mb-4">
            <h1>Nueva contraseña</h1>
            <p class="text-white-50 small">Ingresa el código enviado y tu nueva clave</p>
        </div>

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-warning small mb-3"></div>

            <div class="mb-3">
                <label asp-for="Token" class="form-label">Código de recuperación</label>
                <input asp-for="Token" class="form-control token-input" placeholder="INGRESA TU CÓDIGO" required />
                <span asp-validation-for="Token" class="text-warning small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label">Contraseña nueva</label>
                <input asp-for="NewPassword" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="NewPassword" class="text-warning small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Confirmar contraseña</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="text-warning small"></span>
            </div>

            <button class="btn btn-update w-100" type="submit">Actualizar contraseña</button>

            <div class="text-center mt-4">
                <a asp-action="Login" class="link-back">
                    <i class="bi bi-arrow-left me-1"></i> Volver al login
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}