@model LoginFormModel
@{
    ViewData["Title"] = "Iniciar sesión";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #8b5cf6 0%, #d946ef 100%);
        --accent-color: #ff5e62;
        --card-bg: #171717; /* Color turquesa del fondo según la imagen */
    }

    body {
        background-color: #f8f9fa;
    }

    .login-container {
        max-width: 450px;
        margin: 5% auto;
    }

    .card-custom {
        background-color: var(--card-bg);
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        color: white;
        padding: 2rem;
    }

    .form-control-custom {
        border-radius: 8px;
        border: 2px solid #fff;
        padding: 0.75rem;
        margin-bottom: 0.5rem;
    }

    .btn-login {
        background-color: var(--accent-color);
        border: none;
        color: white;
        font-weight: bold;
        padding: 12px;
        border-radius: 10px;
        transition: transform 0.2s;
    }

        .btn-login:hover {
            background-color: #ff4141;
            transform: translateY(-2px);
            color: white;
        }

    .forgot-link {
        color: #ffc107;
        text-decoration: none;
        font-size: 0.9rem;
    }

    .register-link {
        color: #d1ff00;
        text-decoration: none;
        font-weight: bold;
    }

    .validation-summary-errors {
        background-color: #c2185b;
        color: white;
        padding: 10px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 0.9rem;
    }
</style>

<div class="login-container">
    <div class="card card-custom">
        <h1 class="h2 mb-4 text-center fw-bold">Iniciar sesión</h1>

        <form asp-action="Login" method="post">
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <div class="mb-3">
                <label class="form-label fw-bold" asp-for="Email">Email</label>
                <input asp-for="Email" class="form-control form-control-custom" placeholder="email@ejemplo.com" />
                <span asp-validation-for="Email" class="badge bg-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold" asp-for="Password">Contraseña</label>
                <input asp-for="Password" type="password" class="form-control form-control-custom" placeholder="••••••••" />
                <span asp-validation-for="Password" class="badge bg-danger"></span>
            </div>

            <div class="text-end mb-4">
                <button type="button" class="btn btn-link p-0 forgot-link" data-bs-toggle="modal" data-bs-target="#forgotPasswordModal">
                    ¿Olvidaste tu contraseña?
                </button>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-login shadow">Entrar</button>
            </div>

            <div class="text-center mt-4">
                <a asp-action="Register" class="register-link">Crear cuenta</a>
            </div>
        </form>
    </div>
</div>

<!-- Modal Personalizado (Diseño de la imagen) -->
<div class="modal fade" id="forgotPasswordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0" style="background-color: #00a8a8; color: white; border-radius: 15px;">
            <div class="modal-header border-0">
                <h2 class="modal-title h5 fw-bold"><i class="bi bi-lock-fill me-2"></i>¿Olvidaste tu contraseña?</h2>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <p class="small">Por favor, ingresa tu correo electrónico para restablecer tu contraseña.</p>
                    <input class="form-control mb-3" name="Email" type="email" placeholder="usuario@correo.com" required />
                </div>
                <div class="modal-footer border-0">
                    <button type="submit" class="btn btn-danger px-4" style="border-radius: 8px;">Enviar código</button>
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}